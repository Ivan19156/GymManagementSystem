@model IEnumerable<GymManagement.Domain.Entities.Trainer>
@{ ViewData["Title"] = "Тренери"; }

<h2>Тренери</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex gap-2 mb-3">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="User" asp-action="Create" class="btn btn-primary">+ Додати</a>
        <a asp-action="Export" class="btn btn-success">⬇ Експорт Excel</a>
        <form asp-action="Import" method="post" enctype="multipart/form-data" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="file" name="file" accept=".xlsx" class="form-control" style="width:auto" />
            <button type="submit" class="btn btn-outline-primary">⬆ Імпорт Excel</button>
        </form>
    }
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ім'я</th>
            <th>Прізвище</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Спеціалізація</th>
            <th>Досвід (років)</th>
            <th>Ставка (грн/год)</th>
            <th>Доступний</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.User.FirstName</td>
                <td>@item.User.LastName</td>
                <td>@item.User.Email</td>
                <td>@item.User.Phone</td>
                <td>@item.Specialization?.Name</td>
                <td>@item.ExperienceYears</td>
                <td>@item.HourlyRate?.ToString("N2")</td>
                <td>
                    @if (item.IsAvailable == true)
                    {
                        <span class="badge bg-success">Так</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ні</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
