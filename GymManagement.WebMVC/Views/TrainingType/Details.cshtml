@model GymManagement.Domain.Entities.TrainingType
@{ ViewData["Title"] = "Деталі типу тренування"; }

<h2>Деталі типу тренування</h2>
<dl class="row">
    <dt class="col-sm-2">Назва</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Категорія</dt>
    <dd class="col-sm-10">@Model.Category?.Name</dd>
    <dt class="col-sm-2">Опис</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
<a asp-action="Index" class="btn btn-secondary">Назад</a>