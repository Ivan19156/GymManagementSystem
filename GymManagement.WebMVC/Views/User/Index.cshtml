@model IEnumerable<GymManagement.Domain.Entities.User>
@{ ViewData["Title"] = "Користувачі"; }
<h2>Користувачі</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Додати</a>
<table class="table table-striped">
    <thead><tr><th>Ім'я</th><th>Прізвище</th><th>Email</th><th>Роль</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.Email</td>
            <td>
                @if (item.Admin != null) { <span class="badge bg-danger">Admin</span> }
                @if (item.Trainer != null) { <span class="badge bg-primary">Trainer</span> }
                @if (item.Client != null) { <span class="badge bg-success">Client</span> }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
            </td>
        </tr>
    }
    </tbody>
</table>