@model GymManagement.Domain.Entities.MembershipPlan
@{ ViewData["Title"] = "Деталі плану"; }
<h2>Деталі плану</h2>
<dl class="row">
    <dt class="col-sm-2">Назва</dt><dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Тип</dt><dd class="col-sm-10">@Model.Type?.Name</dd>
    <dt class="col-sm-2">Ціна</dt><dd class="col-sm-10">@Model.Price</dd>
    <dt class="col-sm-2">Тривалість</dt><dd class="col-sm-10">@Model.DurationDays днів</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
<a asp-action="Index" class="btn btn-secondary">Назад</a>