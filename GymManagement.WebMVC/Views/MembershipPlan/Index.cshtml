@model IEnumerable<GymManagement.Domain.Entities.MembershipPlan>
@{ ViewData["Title"] = "Плани абонементів"; }
<h2>Плани абонементів</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Додати</a>
<table class="table table-striped">
    <thead><tr><th>Назва</th><th>Тип</th><th>Ціна</th><th>Тривалість (днів)</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Type?.Name</td>
            <td>@item.Price</td>
            <td>@item.DurationDays</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
            </td>
        </tr>
    }
    </tbody>
</table>