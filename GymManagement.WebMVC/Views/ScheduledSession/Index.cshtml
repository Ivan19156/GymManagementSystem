@model IEnumerable<GymManagement.Domain.Entities.ScheduledSession>
@{ ViewData["Title"] = "Заплановані заняття"; }
<h2>Заплановані заняття</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Додати</a>
<table class="table table-striped">
    <thead>
    <tr>
        <th>Клієнт</th><th>Тренер</th><th>Тип тренування</th>
        <th>Дата</th><th>Час</th><th>Статус</th><th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Client?.User?.FirstName @item.Client?.User?.LastName</td>
            <td>@item.Trainer?.User?.FirstName @item.Trainer?.User?.LastName</td>
            <td>@item.TrainingType?.Name</td>
            <td>@item.SessionDate.ToShortDateString()</td>
            <td>@item.StartTime - @item.EndTime</td>
            <td>@item.Status?.Name</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
            </td>
        </tr>
    }
    </tbody>
</table>